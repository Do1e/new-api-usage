# Database Configuration
DATABASE_URL=postgres://username:password@localhost:5432/database_name

# Dashboard Login Password
DASHBOARD_PASSWORD=your_secure_password_here

# Session Secret (use a long random string, generate one using a tool like `openssl rand -base64 32`)
SESSION_SECRET=replace_with_a_random_secret

# Default date range for dashboard queries (N = last N days, 0 = all data)
DEFAULT_RECENT_DAYS=7
