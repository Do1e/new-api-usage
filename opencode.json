{
  "mcp": {
    "shadcn": {
      "type": "local",
      "command": ["npx", "shadcn@latest", "mcp"],
      "enabled": true
    },
    "lucide-icons": {
      "type": "local",
      "command": ["npx", "lucide-icons-mcp", "--stdio"],
      "enabled": true
    },
    "new-api-data": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-postgres", "{env:DATABASE_URL}"],
      "enabled": true
    }
  },
  "$schema": "https://opencode.ai/config.json"
}
