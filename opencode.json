{
  "mcp": {
    "shadcn": {
      "type": "local",
      "command": ["npx", "shadcn@latest", "mcp"],
      "enabled": true
    },
    "lucide-icons": {
      "type": "local",
      "command": ["npx", "lucide-icons-mcp", "--stdio"],
      "enabled": true
    },
    "new-api-data": {
      "type": "local",
      "command": ["sh", "-c", "set -a; . ./.env; set +a; exec npx -y @modelcontextprotocol/server-postgres \"$DATABASE_URL\""],
      "enabled": true
    }
  },
  "$schema": "https://opencode.ai/config.json"
}
